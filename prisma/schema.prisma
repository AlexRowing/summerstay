// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One apartment listing. Mirrors the Listing type the app already uses.
model Listing {
  id               String   @id @default(cuid())
  title            String
  city             String
  neighborhood     String
  pricePerMonth    Int
  bedrooms         Int
  bathrooms        Int
  distanceToCampus String
  availability     String
  description      String
  // Stored as a JSON string and parsed in app/_lib/listings.ts. Kept as-is
  // through the SQLite->Postgres migration to keep the schema identical; a
  // later change can switch this to a native Postgres text[] array.
  amenities        String
  imageUrl         String
  createdAt        DateTime @default(now())
  inquiries        Inquiry[]
  // Who posted this listing. Nullable because the seeded starter listings have
  // no owner; listings created through the form after auth get an owner.
  owner            User?     @relation(fields: [ownerId], references: [id])
  ownerId          String?
}

// A registered host/renter. Passwords are stored only as a bcrypt hash.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())
  listings     Listing[]
}

// A message from a prospective subletter about one listing. This is the
// honest, scoped version of "contact host": it records interest; it is not a
// full messaging system.
model Inquiry {
  id        String   @id @default(cuid())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
